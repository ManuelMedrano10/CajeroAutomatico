<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <title>{{title}}</title>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg bg-dark border-bottom border-body" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">ATM</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="/">Home</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container">
        <div class="row d-flex justify-content-center mt-4">
            <div class="col-12 col-sm-5 col-md-5">
                <h1 class="display-5 fw-bold text-start">Retiro de Efectivo</h1>
                <div class="card">
                    {{#if error}}
                    <div class="alert alert-danger alert-dismissible" role="alert">
                        <div>{{error}}</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    {{/if}}

                    <div class="card-header bg-secondary text-light">
                        <h5 class="text-center fw-bold">Monto a retirar:</h5>
                    </div>
                    <div class="card-body">
                        <form class="/" method="post">
                            <div class="mb-3">
                                <label for="withdraw-amount" class="form-label">Cantidad:</label>
                                <input type="number" name="Amount" id="withdraw-amount" class="form-control"
                                    required="required" />
                            </div>
                            <div class="mb-3">
                                <label for="withdraw-mode" class="form-label">Modo de dispension:</label>
                                <select name="mode" id="withdraw-mode" class="form-select" required="required">
                                    <option value="1">Papeletas 200/1000</option>
                                    <option value="2">Papeletas 100/500</option>
                                    <option value="3" selected="selected">Modo eficiente</option>
                                </select>
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success float-center"><i class="bi bi-cash"></i>
                                    Retirar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer></footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>